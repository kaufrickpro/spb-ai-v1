NODE_ENV=development
APP_CONFIG_MODE=local
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
API_AUTH_MODE=test
STORAGE_PROVIDER=local
DOCUMENT_PROCESSING_PROVIDER=local

# Development-only value. Change this to your public app domain in production.
WEB_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000
AI_SERVICE_BASE_URL=http://localhost:8000
DOCUMENT_SCANNER_MODE=local_fake
DOCUMENT_SCANNER_PROVIDER=
DOCUMENT_SCANNER_LAUNCH_DECISION_ID=

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_PLACEHOLDER
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER
FIRST_ADMIN_EMAIL_ALLOWLIST=admin@example.com

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=europe-west3
GCS_BUCKET_PRIVATE_UPLOADS=publisher-author-private
