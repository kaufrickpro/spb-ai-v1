CLOUD_TASKS_MATCHING_QUEUE=matching-local
CLOUD_TASKS_INGESTION_QUEUE=ingestion-local
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=spb-cloud-tasks-staging@your-gcp-project-id.iam.gserviceaccount.com

PAYTR_MODE=sandbox
PAYTR_MERCHANT_ID=PAYTR_MERCHANT_ID_PLACEHOLDER
PAYTR_MERCHANT_KEY=PAYTR_MERCHANT_KEY_PLACEHOLDER
PAYTR_MERCHANT_SALT=PAYTR_MERCHANT_SALT_PLACEHOLDER

RESEND_API_KEY=RESEND_API_KEY_PLACEHOLDER
RESEND_FROM_ADDRESS=notifications@example.com
RESEND_WEBHOOK_SECRET=RESEND_WEBHOOK_SECRET_PLACEHOLDER

SENTRY_DSN=
