# Staging AI service environment template.
# Replace placeholders during deployment. Server-only secrets belong in Secret Manager.

APP_CONFIG_MODE=staging
APP_NAME=ai-service
APP_PORT=8000
AI_PROVIDER_MODE=vertex
STORAGE_PROVIDER=gcs

SUPABASE_URL=https://STAGING_SUPABASE_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging-supabase-service-role-key-secret>

GCS_BUCKET_PRIVATE_UPLOADS=spb-ai-staging-manuscripts
GOOGLE_CLOUD_PROJECT=spb-ai
GOOGLE_CLOUD_REGION=europe-west3

# Real-user staging uploads require real scanner config from Secret Manager.
# See infra/scripts/put-scanner-secrets.sh for the expected secret names.
DOCUMENT_SCANNER_MODE=real
LOCAL_FAKE_SCANNER_RESULT=not_scanned
DOCUMENT_SCANNER_LAUNCH_DECISION_ID=
DOCUMENT_SCANNER_PROVIDER=http-clamav
DOCUMENT_SCANNER_ENDPOINT=<spb-ai-staging-document-scanner-endpoint-secret>
DOCUMENT_SCANNER_TOKEN=<spb-ai-staging-document-scanner-token-secret>
DOCUMENT_SCANNER_TIMEOUT_SECONDS=<spb-ai-staging-document-scanner-timeout-seconds-secret>
DOCUMENT_SCANNER_CLOUD_RUN_AUDIENCE=https://spb-document-scanner-staging-PLACEHOLDER.a.run.app

VERTEX_PROJECT_ID=spb-ai
VERTEX_LOCATION=europe-west3
VERTEX_AI_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_AI_VECTOR_INDEX=publisher-author-staging-vector-index
VERTEX_AI_VECTOR_INDEX_ID=6107839868853813248
VERTEX_AI_INDEX_ENDPOINT_ID=737156575726141440
VERTEX_AI_DEPLOYED_INDEX_ID=publisher_author_staging_v1
VERTEX_AI_PSC_NETWORK=projects/spb-ai/global/networks/spb-ai-staging-vpc
VERTEX_AI_VECTOR_SEARCH_QUERY_HOST=http://10.42.1.2
VERTEX_AI_PSC_SERVICE_CONNECTION_POLICY=projects/spb-ai/locations/europe-west3/serviceConnectionPolicies/spb-ai-staging-vertex-psc
VERTEX_AI_PSC_RUN_SUBNET=projects/spb-ai/regions/europe-west3/subnetworks/spb-ai-staging-run-euw3
VERTEX_AI_PSC_ENDPOINT_SUBNET=projects/spb-ai/regions/europe-west3/subnetworks/spb-ai-staging-psc-euw3
VERTEX_AI_PSC_MATCH_ADDRESS=10.42.1.2

MATCH_EXPLANATION_PROVIDER=vertex_gemini
VERTEX_GEMINI_EXPLANATION_MODEL=gemini-2.5-flash
MATCHING_ALGORITHM_VERSION=v1
MATCHING_FILTER_VERSION=v1
MATCHING_EXPLANATION_VERSION=v1

INGESTION_TIMEOUT_SECONDS=300
MATCH_TIMEOUT_SECONDS=60
MAX_UPLOAD_BYTES=26214400
MAX_EXTRACTED_CHARACTERS=250000
MAX_CHUNKS_PER_DOCUMENT=300
MAX_CANDIDATES_PER_MATCH=25

SENTRY_DSN=STAGING_AI_SERVICE_SENTRY_DSN_PLACEHOLDER
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=ai-service@GIT_SHA_PLACEHOLDER
SENTRY_TRACES_SAMPLE_RATE=0.1
