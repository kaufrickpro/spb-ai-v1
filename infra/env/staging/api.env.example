# Staging API environment template.
# Replace placeholders during deployment. Server-only secrets belong in Secret Manager.

NODE_ENV=production
APP_CONFIG_MODE=staging
APP_NAME=api
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

WEB_APP_URL=https://spb-ai.dev
API_BASE_URL=https://staging-api.spb-ai.dev

API_AUTH_MODE=supabase
SUPABASE_URL=https://STAGING_SUPABASE_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=STAGING_SUPABASE_ANON_KEY_PLACEHOLDER
SUPABASE_SERVICE_ROLE_KEY=<staging-supabase-service-role-key-secret>
FIRST_ADMIN_EMAIL_ALLOWLIST=admin@example.com

STORAGE_PROVIDER=gcs
GCS_BUCKET_PRIVATE_UPLOADS=spb-ai-staging-manuscripts
GCS_SIGNED_URL_TTL_SECONDS=900

DOCUMENT_PROCESSING_PROVIDER=cloud_tasks
GOOGLE_CLOUD_PROJECT=spb-ai
GOOGLE_CLOUD_REGION=europe-west3
CLOUD_TASKS_INGESTION_QUEUE=document-processing-staging
CLOUD_TASKS_MATCHING_QUEUE=matching-staging
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=spb-cloud-tasks-staging@spb-ai.iam.gserviceaccount.com
AI_SERVICE_BASE_URL=https://spb-ai-service-staging-PLACEHOLDER.a.run.app

DOCUMENT_SCANNER_MODE=real
DOCUMENT_SCANNER_PROVIDER=http-clamav
DOCUMENT_SCANNER_LAUNCH_DECISION_ID=

PAYTR_MODE=sandbox
PAYTR_MERCHANT_ID=<staging-paytr-merchant-id-secret>
PAYTR_MERCHANT_KEY=<staging-paytr-merchant-key-secret>
PAYTR_MERCHANT_SALT=<staging-paytr-merchant-salt-secret>

RESEND_API_KEY=<staging-resend-api-key-secret>
RESEND_FROM_ADDRESS=support@mail.spb-ai.dev
RESEND_WEBHOOK_SECRET=<staging-resend-webhook-secret>

SENTRY_DSN=STAGING_API_SENTRY_DSN_PLACEHOLDER
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=api@GIT_SHA_PLACEHOLDER
SENTRY_TRACES_SAMPLE_RATE=0.1
