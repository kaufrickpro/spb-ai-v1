# Root environment template for local development.
# Copy values into service-specific .env files as needed.
# These localhost URLs are development-only placeholders and must be replaced
# with your real domain during production setup.

APP_ENV=local
APP_NAME=Publisher Author Marketplace

WEB_PORT=5173
API_PORT=4000
AI_SERVICE_PORT=8000

WEB_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000
AI_SERVICE_BASE_URL=http://localhost:8000

DOCUMENT_SCANNER_MODE=local_fake
DOCUMENT_SCANNER_PROVIDER=
DOCUMENT_SCANNER_ENDPOINT=
DOCUMENT_SCANNER_TOKEN=
DOCUMENT_SCANNER_TIMEOUT_SECONDS=
DOCUMENT_SCANNER_LAUNCH_DECISION_ID=
LOCAL_FAKE_SCANNER_RESULT=not_scanned

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_PLACEHOLDER
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=europe-west3

SENTRY_ENVIRONMENT=local
